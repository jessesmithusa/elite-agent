# Per-profile environment overrides
# Load this AFTER your base .env to customize for a specific environment

# Target address the agent answers for
EA_TARGET_ADDRESS=coach@example.com

# Agent persona name
EA_PERSONA_NAME=Coach

# Email signature
EA_SIGNATURE=--\nBest regards,\nCoach

# Outbox directory for this profile
EA_OUTBOX_DIR=./outbox/prod

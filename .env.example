# Mail server configuration
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=your_email@example.com
IMAP_PASS=your_imap_password
IMAP_MAILBOX=INBOX
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=coach@example.com

# LLM configuration
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-mini
OPENAI_CHAT_URL=https://api.openai.com/v1/chat/completions

# Agent behavior
EA_ENABLED=1
EA_DRY_RUN=1
EA_TARGET_ADDRESS=coach@example.com
EA_PERSONA_NAME=Coach
EA_SIGNATURE=
EA_ORG_CONTEXT=
EA_ORG_CONTEXT_FILE=
EA_BRAIN=olympic
EA_CARDS_DIR=
EA_REQUIRE_REPLY_ALLOWLIST=1
EA_ALLOW_SENDERS=
EA_ALLOW_REPLY_DOMAINS=
EA_SKIP_DOMAINS=
EA_AUTO_REPLY_INTENTS=question,support,general
EA_MIN_LLM_CONFIDENCE=0.6
EA_MAX_MESSAGES_PER_RUN=10
EA_MAX_UID_SCAN=200
EA_MAX_EMAIL_CHARS=8000
EA_MAX_SENDS_PER_HOUR=10
EA_STATE_FILE=./state/state.json
EA_AUDIT_FILE=./state/audit.jsonl
EA_OUTBOX_DIR=./outbox
EA_REVIEW_DIR=./outbox/review
EA_ESCALATE_EMAIL=
EA_WRITE_DRAFTS=1
EA_LOG_LLM_IO=0
EA_LLM_LOG_DIR=./state/llm
EA_OPENAI_TIMEOUT_SEC=60
EA_INTERPRET_MAX_TOKENS=800
EA_DRAFT_MAX_TOKENS=800
